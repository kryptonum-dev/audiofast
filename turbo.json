{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalEnv": [
    "SANITY_API_READ_TOKEN",
    "SANITY_API_WRITE_TOKEN",
    "VERCEL_URL",
    "VERCEL_PROJECT_PRODUCTION_URL",
    "VERCEL_ENV",
    "NODE_ENV",
    "EMBEDDINGS_INDEX_BEARER_TOKEN",
    "MAILCHIMP_API_KEY",
    "MAILCHIMP_SERVER_PREFIX",
    "NEXT_REVALIDATE_TOKEN",
    "AZURE_TENANT_ID",
    "AZURE_CLIENT_ID",
    "AZURE_CLIENT_SECRET",
    "MS_GRAPH_SENDER_EMAIL",
    "MS_GRAPH_REPLY_TO",
    "VERCEL_API_TOKEN",
    "SANITY_WEBHOOK_SECRET",
    "SUPABASE_SERVICE_ROLE_KEY",
    "SUPABASE_ORDER_INVOICES_BUCKET",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "B2C_ADMIN_SANITY_ORGANIZATION_ID",
    "B2C_ADMIN_SANITY_API_VERSION",
    "B2C_ADMIN_ALLOWED_EMAILS",
    "B2C_ADMIN_ALLOWED_USER_IDS",
    "B2C_ADMIN_ALLOWED_ORIGINS",
    "LIMIT_BUILD_TIME_STATIC_PARAMS",
    "E2E_AUTH_HELPER_SECRET",
    "E2E_MOCK_EMAILS",
    "E2E_MOCK_MAILCHIMP",
    "E2E_DISABLE_ANALYTICS",
    "P24_API_KEY",
    "P24_MERCHANT_ID",
    "P24_POS_ID",
    "P24_CRC",
    "P24_API_BASE_URL",
    "P24_PANEL_BASE_URL",
    "P24_STATUS_ALLOWED_IPS",
    "P24_REQUEST_TIMEOUT_MS",
    "P24_FORCE_MOCK",
    "P24_MODE"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", ".sanity/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
