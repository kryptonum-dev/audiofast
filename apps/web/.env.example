# Local web app environment template.
# Copy this file to .env.local and fill values for your local development
# environment. Never commit .env.local.

# Sanity content source used by the web app.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
NEXT_PUBLIC_SANITY_API_VERSION=
NEXT_PUBLIC_SANITY_STUDIO_URL=
NEXT_PUBLIC_SANITY_API_READ_TOKEN=
SANITY_AUTH_TOKEN=

# Supabase project used by the web app.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App/runtime tokens.
NEXT_REVALIDATE_TOKEN=
EMBEDDINGS_INDEX_BEARER_TOKEN=
VERCEL_OIDC_TOKEN=

# B2C admin App SDK bridge.
# Use comma-separated values. B2C_ADMIN_ALLOWED_ORIGINS is required; the
# bridge fails closed when it is empty. In local development only, a verified
# Sanity project member is allowed when no operator allowlist is configured.
B2C_ADMIN_SANITY_ORGANIZATION_ID=
B2C_ADMIN_SANITY_API_VERSION=
B2C_ADMIN_ALLOWED_EMAILS=
B2C_ADMIN_ALLOWED_USER_IDS=
B2C_ADMIN_ALLOWED_ORIGINS=

# Przelewy24 payment integration. Leave P24_MODE empty for local mock mode.
# Never expose P24_API_KEY or P24_CRC through NEXT_PUBLIC_* variables.
P24_MODE=
P24_MERCHANT_ID=
P24_POS_ID=
P24_API_KEY=
P24_CRC=
P24_API_BASE_URL=
P24_PANEL_BASE_URL=
P24_STATUS_ALLOWED_IPS=
P24_REQUEST_TIMEOUT_MS=
P24_FORCE_MOCK=

# E2E/test safety switches. Leave empty for normal local development.
E2E_MOCK_EMAILS=
E2E_MOCK_MAILCHIMP=
E2E_DISABLE_ANALYTICS=
E2E_AUTH_HELPER=
E2E_AUTH_HELPER_SECRET=

# Optional email and marketing integrations.
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=

# Microsoft Graph / Azure integrations.
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
MS_GRAPH_SENDER_EMAIL=
MS_GRAPH_REPLY_TO=
