# Playwright / E2E environment template.
# Copy this file to .env.e2e.local and fill values from the dedicated
# Supabase E2E project. Never commit .env.e2e.local.

# Sanity content source used by the web app during E2E runs.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
NEXT_PUBLIC_SANITY_API_VERSION=
NEXT_PUBLIC_SANITY_STUDIO_URL=
NEXT_PUBLIC_SANITY_API_READ_TOKEN=

# Dedicated Supabase E2E project, not production.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional external integrations. Prefer test/stub credentials for E2E.
SANITY_AUTH_TOKEN=
NEXT_REVALIDATE_TOKEN=
EMBEDDINGS_INDEX_BEARER_TOKEN=
VERCEL_OIDC_TOKEN=

# E2E/test safety switches. Keep enabled for Playwright runs.
E2E_MOCK_EMAILS=1
E2E_MOCK_MAILCHIMP=1
E2E_DISABLE_ANALYTICS=1
E2E_AUTH_HELPER=1
E2E_AUTH_HELPER_SECRET=

# Playwright uses the local Przelewy24 mock by default. Do not add real P24
# credentials here unless running a separate opt-in sandbox smoke test.
P24_FORCE_MOCK=1
P24_MODE=
P24_MERCHANT_ID=
P24_POS_ID=
P24_API_KEY=
P24_CRC=

MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=

AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
MS_GRAPH_SENDER_EMAIL=
MS_GRAPH_REPLY_TO=
